{
  "cli": {
    "version": ">= 18.8.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development"
    },
     "preview": {
      "channel": "preview",
      "android": {
        "buildType": "apk"
      }
    },
    "diawi": {
      "ios": {
        "simulator": false,
        "enterpriseProvisioning": "adhoc"
      },
      "distribution": "internal"
    },
    "production": {
      "autoIncrement": true,
      "channel": "production"
    }
  },
  "submit": {
    "production": {}
  }
}
